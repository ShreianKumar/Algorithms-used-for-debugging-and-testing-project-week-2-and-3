# --- Color Ranges (HSV) --- # Based on the debug code values
COLOR_RANGES = {
    "RED_LOW":  {"low": np.array([0, 100, 100]),   "high": np.array([10, 255, 255])},
    "RED_HIGH": {"low": np.array([160, 100, 100]), "high": np.array([180, 255, 255])},
    "YELLOW":   {"low": np.array([20, 100, 100]),  "high": np.array([40, 255, 255])},
    "BLACK":    {"low": np.array([0, 0, 0]),       "high": np.array([180, 255, 137])}
}

def get_line_centroid(hsv, color_name):
    
    if color_name == "RED":
        # Double Red Logic: Combine the 0-10 and 160-180 ranges
        mask1 = cv2.inRange(hsv, COLOR_RANGES["RED_LOW"]["low"], COLOR_RANGES["RED_LOW"]["high"])
        mask2 = cv2.inRange(hsv, COLOR_RANGES["RED_HIGH"]["low"], COLOR_RANGES["RED_HIGH"]["high"])
        mask = cv2.bitwise_or(mask1, mask2)
    else:
        # Standard logic for Yellow and Black
        lower = COLOR_RANGES[color_name]["low"]
        upper = COLOR_RANGES[color_name]["high"]
        mask = cv2.inRange(hsv, lower, upper)
    
    # Clean up the noise
    mask = cv2.dilate(cv2.erode(mask, None, iterations=2), None, iterations=2)
    
    contours, _ = cv2.findContours(mask, cv2.RETR_EXTERNAL, cv2.CHAIN_APPROX_NONE)
    if len(contours) > 0:
        c = max(contours, key=cv2.contourArea) # added to fix noise (final edit)
        if cv2.contourArea(c) > 500:
            M = cv2.moments(c)
            if M['m00'] != 0:
                return int(M['m10'] / M['m00']), int(M['m01'] / M['m00']), mask
            
    return None, None, mask

def set_motor(left, right, mode="FORWARD"):
