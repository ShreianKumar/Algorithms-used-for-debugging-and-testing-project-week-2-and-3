import cv2
import numpy as np
from picamera2 import Picamera2
from collections import deque

orb = cv2.ORB_create(nfeatures= 400, fastThreshold = 30) #feature detection reduced from 1000
bf = cv2.BFMatcher(cv2.NORM_HAMMING, crossCheck=True)

# --- 2. Buffer Setup ---
# This stores the last 5 detections to ensure stability
recognition_buffer = deque(maxlen=5)

template_files = {
    "Button Code": "/home/rasp4/Downloads/Button code_05.04.2026.png",
    "Fingerprint": "/home/rasp4/Downloads/Fingerprint full_05.04.2026.png",
    "Recycle": "/home/rasp4/Downloads/Recycle full_05.04.2026.png",
    "Warning": "/home/rasp4/Downloads/Warning_07.04.2026.png",
    "QR Code": "/home/rasp4/Downloads/QR code full_05.04.2026.png"
}

template_data = {}
for name, path in template_files.items():
    img = cv2.imread(path, cv2.IMREAD_GRAYSCALE) # This ignores color!
    if img is not None:
        kp, des = orb.detectAndCompute(img, None)
        template_data[name] = des

def classify_template(frame):
    # Convert camera frame to Grayscale so color is ignored
    gray_frame = cv2.cvtColor(frame, cv2.COLOR_BGR2GRAY)
    
    kp_query, des_query = orb.detectAndCompute(gray_frame, None)
    
    current_best = "Unknown"
    max_good_matches = 0
    
    if des_query is not None:
        for name, des_train in template_data.items():
            if des_train is not None:
                matches = bf.match(des_train, des_query)
                # Filter for quality (m.distance < 30 is a good standard)
                good_matches = [m for m in matches if m.distance < 30]
                
                if len(good_matches) > max_good_matches:
                    max_good_matches = len(good_matches)
                    current_best = name

    # --- 3. The Buffer Logic ---
    # If matches are too low, consider this frame "Unknown"
    if max_good_matches < 10:
        recognition_buffer.append("Unknown")
    else:
        recognition_buffer.append(current_best)

    # Only display the name if it is the most common item in our 5-frame buffer
    # This filters out "flickering" wrong guesses
    final_decision = max(set(recognition_buffer), key=recognition_buffer.count)

    # --- 4. UI Display ---
    display_color = (0, 255, 0) if final_decision != "Unknown" else (0, 0, 255)
    cv2.putText(frame, f"Identity: {final_decision}", (10, 40), 
                cv2.FONT_HERSHEY_SIMPLEX, 0.7, display_color, 2)
    
    cv2.imshow("Color-Agnostic Recognition", frame)
    
    return final_decision
    




