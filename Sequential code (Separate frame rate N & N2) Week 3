import cv2
import numpy as np
from collections import deque

recognition_buffer = deque(maxlen=3)
kernel = cv2.getStructuringElement(cv2.MORPH_RECT, (5, 5))

def classify_symbol(frame):
    current_identity = "Unknown"
    gray = cv2.cvtColor(frame, cv2.COLOR_BGR2GRAY)
    blur = cv2.GaussianBlur(gray, (5, 5), 0)
    thresh = cv2.adaptiveThreshold(blur, 255, cv2.ADAPTIVE_THRESH_GAUSSIAN_C, 
                                        cv2.THRESH_BINARY_INV, 51, 7)
    mask = cv2.morphologyEx(thresh, cv2.MORPH_CLOSE, kernel)
    
    contours, hierarchy = cv2.findContours(mask, cv2.RETR_TREE, cv2.CHAIN_APPROX_SIMPLE) #cv2.RETR_EXTERNAL was switched to cv2.RETR_TREE
    
    found = False
    if hierarchy is not None:
        # We use hierarchy[0] because it's a 3D array
        for i, cnt in enumerate(contours):
            
            # 2. THE KILLER FILTER: Check for "children"
            # hierarchy[0][i][2] is the index of the first child contour.
            # If it's NOT -1, this shape has stuff inside it (like a QR code or Template).
            # Arrows are solid blocks; they should have NO internal shapes.
            if hierarchy[0][i][2] != -1:
                continue # This is a complex sign/QR, skip it!
        
            area = cv2.contourArea(cnt)
        #print(f"Area:{area}")
            if 600 < area < 8000:
                x, y, w, h = cv2.boundingRect(cnt)
                aspect_ratio = float(w) / h
                #print(f"Aspect:{aspect_ratio}")
                if 0.5 <= aspect_ratio <= 2.5:
                    hull = cv2.convexHull(cnt)
                    solidity = float(area) / cv2.contourArea(hull) if cv2.contourArea(hull) > 0 else 0
                    #print(f"Solidity:{solidity}")
                
            
                # Arrows have a distinct solidity (0.52 - 0.75)
                    if 0.3 <= solidity <= 0.65:  #Threshold was reduced from 0.53 to 0.3 after testing values
                        M = cv2.moments(cnt)
                        if M["m00"] > 0:
                            cX, cY = int(M["m10"]/M["m00"]), int(M["m01"]/M["m00"])
                            bX, bY = x + (w/2), y + (h/2)
    
                            if abs(cX - bX) > abs(cY - bY):
                                current_identity = "Arrow Right" if cX > bX else "Arrow Left"
                            #else:
                                #current_identity = "Arrow Down" if cY > bY else "Arrow Up"
                            found = True
                            break 
                        
    if not found:
        current_identity = "Unknown"
                        
    recognition_buffer.append(current_identity)
    final_decision = max(set(recognition_buffer), key=recognition_buffer.count)
        
    color = (0, 255, 0) if final_decision != "Unknown" else (0, 0, 255)
    cv2.putText(frame, f"ID: {final_decision}", (10, 40), 1, 1.5, color, 2)
    cv2.imshow("Homography Hybrid System", frame)
    
    return final_decision
        
